SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Shared team login
APP_PASSWORD=change-me-to-a-team-password
# Generate with: openssl rand -hex 32
AUTH_SECRET=change-me-to-a-long-random-string

# Completion emails (Resend — https://resend.com). Without RESEND_API_KEY,
# completion notifications are skipped silently. RESEND_FROM must use a domain
# verified in your Resend account.
RESEND_API_KEY=
RESEND_FROM=Eaveside <noreply@eaveside.com>
